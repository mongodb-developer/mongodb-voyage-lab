{
    "name": "MongoDB VoyageAI Lab",
    "dockerComposeFile": "docker-compose.yml",
    "service": "lab-runner",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "forwardPorts": [8888, 27017],
    "hostRequirements": {
        "cpus": 4
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
    },
    "containerEnv": {
        "MONGODB_URI": "mongodb://admin:mongodb@mongodb:27017/?directConnection=true",
        "NODE_PATH": "/workspaces/${localWorkspaceFolderBasename}/node_modules",
        "VOYAGE_API_KEY": "${localEnv:VOYAGE_API_KEY}"
    },
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-toolsai.jupyter",
                "mongodb.mongodb-vscode"
            ]
        }
    }
}
